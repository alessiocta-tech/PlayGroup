# ── Database ──────────────────────────────────────────────────────────────────
# DEV: docker-compose locale
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/playgroup"
# PROD Railway (copia da Railway dashboard → PostgreSQL plugin → Connect)
# DATABASE_URL="postgresql://user:pass@railway-host:5432/playgroup"

REDIS_URL="redis://localhost:6379/0"
# PROD Railway (copia da Railway dashboard → Redis plugin → Connect)
# REDIS_URL="redis://railway-redis:6379/0"

# ── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# PROD:
# NEXTAUTH_URL="https://playgroupsrl.it"

# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-con-stringa-random-sicura"

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHAPI_TOKEN=""
WHAPI_BASE_URL="https://gate.whapi.cloud"

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ── Google OAuth ──────────────────────────────────────────────────────────────
# 1. Crea credenziali OAuth 2.0 su console.cloud.google.com
# 2. Abilita: Gmail API, Calendar API, People API, Tasks API, Drive API
# 3. Aggiungi redirect URI: https://playgroupsrl.it/api/google-auth
# 4. Vai su https://playgroupsrl.it/api/google-auth per ottenere il refresh token
# 5. Copia GOOGLE_REFRESH_TOKEN nelle env Railway
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""
# DEV redirect (non serve in prod, la route /api/google-auth gestisce tutto)
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google-auth"
# Email Google da usare come login hint (es. tua@gmail.com)
GOOGLE_LOGIN_HINT=""

# ── deRione KPI (sync automatico ogni ora) ────────────────────────────────────
# Endpoint API del sistema deRione che espone i KPI giornalieri
# Risposta attesa: { date, revenue, bookings, covers } oppure array
DERIONE_KPI_URL=""
DERIONE_KPI_TOKEN=""

# ── Fattura24 ─────────────────────────────────────────────────────────────────
FATTURA24_API_KEY=""

# ── Home Assistant ────────────────────────────────────────────────────────────
HOME_ASSISTANT_URL=""
HOME_ASSISTANT_TOKEN=""
# Secret opzionale per verificare i webhook in arrivo da HA
HA_WEBHOOK_SECRET=""

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL="http://localhost:3000"
# PROD:
# NEXT_PUBLIC_URL="https://playgroupsrl.it"
ENVIRONMENT="development"

# ── Sicurezza (solo PROD — Fase 9) ────────────────────────────────────────────
